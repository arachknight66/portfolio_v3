# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real tokens.

# GitHub read-only token (public repos only)
# Used in R3 Builder footer to show live commit count
# Leave empty to show static fallback text instead
NEXT_PUBLIC_GITHUB_TOKEN=

# Your GitHub username
NEXT_PUBLIC_GITHUB_USERNAME=arachknight66
